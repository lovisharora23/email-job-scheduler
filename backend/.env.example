DATABASE_URL=postgresql://user:pass@localhost:5432/reachinbox
REDIS_URL=redis://localhost:6379

PORT=4000
NODE_ENV=development

# BullMQ / worker
WORKER_CONCURRENCY=5
RATE_LIMIT_MAX=10
RATE_LIMIT_DURATION_MS=2000

# Google OAuth — get these from console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

FRONTEND_URL=http://localhost:3000
SESSION_SECRET=supersecretvalue-change-in-production

# Ethereal — auto-generated on first run if left blank (check server logs)
ETHEREAL_USER=
ETHEREAL_PASS=
MIN_DELAY_MS=2000
